# ===================================
# OnionRP Streaming Tool — Конфигурация
# Скопируйте в .env и заполните реальными значениями
# ===================================

# --- Общие настройки ---
NODE_ENV=production
HOST=0.0.0.0

# --- Порты ---
SERVER_PORT=3001
WEB_PORT=13777

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_redis_password

# --- JWT ---
JWT_SECRET=change_me_very_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=24h

# --- Стример (главный пароль) ---
STREAMER_PASSWORD=change_me_streamer_password

# --- Ключи модератора ---
MODERATOR_KEY_TTL=600

# --- WebRTC / mediasoup ---
MEDIASOUP_LISTEN_IP=0.0.0.0
# Укажите публичный IP вашего VPS
MEDIASOUP_ANNOUNCED_IP=YOUR_PUBLIC_IP
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999
MEDIASOUP_LOG_LEVEL=warn

# --- TURN сервер ---
TURN_SERVER_URL=turn:YOUR_PUBLIC_IP:3478
TURN_SERVER_USERNAME=onionrp
TURN_SERVER_PASSWORD=change_me_turn_password

# --- Медиахранилище ---
MEDIA_UPLOAD_DIR=/app/media
MEDIA_MAX_FILE_SIZE=52428800
MEDIA_MAX_VIDEO_DURATION=300

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS (URL фронтенда) ---
CORS_ORIGIN=http://YOUR_DOMAIN_OR_IP:13777
