# ===================================
# OnionRP Streaming Tool — Конфигурация
# ===================================

# --- Общие настройки ---
NODE_ENV=production
HOST=0.0.0.0

# --- Серверный порт ---
SERVER_PORT=3000

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# --- JWT ---
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRES_IN=24h

# --- Стример (главный пароль) ---
STREAMER_PASSWORD=your_streamer_password_here

# --- Ключи модератора ---
MODERATOR_KEY_TTL=600

# --- WebRTC / mediasoup ---
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=95.165.172.153
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
MEDIASOUP_LOG_LEVEL=warn

# --- TURN сервер ---
TURN_SERVER_URL=turn:95.165.172.153:3478
TURN_SERVER_USERNAME=onionrp
TURN_SERVER_PASSWORD=your_turn_password_here

# --- Медиахранилище ---
MEDIA_UPLOAD_DIR=/app/media
MEDIA_MAX_FILE_SIZE=52428800
MEDIA_MAX_VIDEO_DURATION=300

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS ---
CORS_ORIGIN=https://dock.onionrp.ru
